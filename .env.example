# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# OpenRouter (LLM for receipt parsing)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-4o-mini

# Bot server
PORT=3200
WEBHOOK_URL=             # Leave empty for polling mode (dev)

# Dashboard mock auth
MOCK_USERNAME=admin
MOCK_PASSWORD=admin123

# Receipts directory (relative to repo root)
RECEIPTS_DIR=./receipts
